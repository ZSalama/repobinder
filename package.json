{
  "name": "repobinder",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "description": "A desktop-first Git worktree manager for local development.",
  "license": "MIT",
  "author": "Zack Salama",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZSalama/repobinder.git"
  },
  "bugs": {
    "url": "https://github.com/ZSalama/repobinder/issues"
  },
  "homepage": "https://github.com/ZSalama/repobinder#readme",
  "keywords": [
    "git",
    "worktree",
    "electron",
    "react",
    "developer-tools",
    "local-first"
  ],
  "main": "dist/desktop/main.js",
  "scripts": {
    "build": "pnpm run build:web && pnpm run build:server && pnpm run build:desktop",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build:server": "rimraf dist/server && esbuild apps/server/src/index.ts --bundle --platform=node --target=node22 --format=cjs --external:bufferutil --external:utf-8-validate --outfile=dist/server/index.js",
    "build:desktop": "tsc -p apps/desktop/tsconfig.json",
    "clean": "rimraf dist dist-web release",
    "desktop": "electron dist/desktop/main.js",
    "desktop:remote": "cross-env REPOBINDER_REMOTE=1 electron dist/desktop/main.js",
    "dev": "pnpm run build && pnpm run desktop",
    "dev:remote": "pnpm run build && pnpm run desktop:remote",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "dist:linux": "pnpm run build && electron-builder --linux --x64",
    "dist:mac": "pnpm run build && electron-builder --mac --x64 --arm64",
    "dist:win": "pnpm run build && electron-builder --win --x64",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p apps/web/tsconfig.json --noEmit && tsc -p apps/server/tsconfig.json --noEmit && tsc -p apps/desktop/tsconfig.json --noEmit"
  },
  "build": {
    "appId": "com.zsalama.repobinder",
    "productName": "RepoBinder",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "dist/desktop/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/server",
        "to": "server"
      },
      {
        "from": "dist-web",
        "to": "dist-web"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Development",
      "maintainer": "Zack Salama <ZSalama@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ZSalama",
        "repo": "repobinder",
        "releaseType": "draft"
      }
    ]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "express": "^5.1.0",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "shadcn": "^4.8.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=22.12",
    "pnpm": ">=11"
  }
}
